+class _PlainFetcher:
+    """Mac patch: drop-in for DataPrefetcher (which relies on CUDA streams).
+    Iterates the loader and moves batches to the target device (mps/cpu)."""
+
+    def __init__(self, loader, device):
+        self.loader = loader
+        self.device = device
+        self._it = iter(loader)
+
+    def next(self):
+        try:
+            inps, targets, _, _ = next(self._it)
+        except StopIteration:
+            self._it = iter(self.loader)
+            inps, targets, _, _ = next(self._it)
+        return inps.to(self.device), targets.to(self.device)
+
